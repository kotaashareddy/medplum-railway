{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "medplum-server /app/medplum.config.json",
    "healthcheckPath": "/healthcheck",
    "restartPolicyType": "ON_FAILURE"
  }
}
